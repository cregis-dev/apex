# Copy this file to `.env.e2e` and fill in the provider secrets you want to use.
# The Rust E2E harness reads this file and generates the final Apex config JSON.

APEX_E2E_LISTEN=127.0.0.1:12356
APEX_E2E_TEAM_ID=e2e-team
APEX_E2E_TEAM_KEY=sk-apex-e2e-team
APEX_E2E_ADMIN_KEY=sk-apex-e2e-admin
APEX_E2E_ROUTER_NAME=e2e-default
APEX_E2E_ROUTER_STRATEGY=priority
APEX_E2E_TEST_MODEL=apex-test-chat
APEX_E2E_ENABLE_MCP=true
APEX_E2E_METRICS_PATH=/metrics

# Upstream 1: primary provider
# The first enabled upstream becomes the primary channel in the generated router rule.
APEX_UPSTREAM_1_ENABLED=true
APEX_UPSTREAM_1_NAME=openai_primary
APEX_UPSTREAM_1_TYPE=openai
APEX_UPSTREAM_1_BASE_URL=https://api.openai.com/v1
APEX_UPSTREAM_1_API_KEY=
APEX_UPSTREAM_1_MODEL=
APEX_UPSTREAM_1_WEIGHT=1

# Upstream 2: optional fallback provider
# Any enabled upstream after slot 1 is added to router fallback_channels by default.
APEX_UPSTREAM_2_ENABLED=false
APEX_UPSTREAM_2_NAME=anthropic_fallback
APEX_UPSTREAM_2_TYPE=anthropic
APEX_UPSTREAM_2_BASE_URL=https://api.anthropic.com
APEX_UPSTREAM_2_ANTHROPIC_BASE_URL=https://api.anthropic.com
APEX_UPSTREAM_2_API_KEY=
APEX_UPSTREAM_2_MODEL=
APEX_UPSTREAM_2_HEADERS_JSON={"anthropic-version":"2023-06-01"}
APEX_UPSTREAM_2_WEIGHT=1

# Alternative to *_MODEL:
# APEX_UPSTREAM_2_MODEL_MAP_JSON={"apex-test-chat":"claude-sonnet-4-20250514"}

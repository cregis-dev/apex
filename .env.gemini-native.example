# Copy to .env.gemini-native and fill in local secrets. Do not commit the copy.

GEMINI_API_KEY=

# Optional overrides.
APEX_GEMINI_NATIVE_MODEL=gemini-2.5-flash
APEX_GEMINI_NATIVE_ALIAS=apex-gemini-native
APEX_GEMINI_NATIVE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
APEX_GEMINI_NATIVE_LISTEN=127.0.0.1:12357

# Set to 1 to also send a native google_search tool payload. This can fail if
# the selected model, account, region, or billing setup does not support it.
APEX_GEMINI_NATIVE_ENABLE_SEARCH=0

{
  "version": "1.0",
  "global": {
    "listen": "0.0.0.0:12356",
    "auth_keys": ["REPLACE-WITH-YOUR-ADMIN-KEY"],
    "timeouts": {
      "connect_ms": 1000,
      "request_ms": 10000,
      "response_ms": 30000
    },
    "retries": {
      "max_attempts": 3,
      "backoff_ms": 100,
      "retry_on_status": [500, 502, 503, 504]
    },
    "gemini_replay": {
      "ttl_hours": 24
    }
  },
  "logging": {
    "level": "info",
    "dir": "/absolute/path/to/apex/logs"
  },
  "data_dir": "/absolute/path/to/apex/data",
  "channels": [
    {
      "name": "openai-coding",
      "provider_type": "openai",
      "base_url": "https://api.openai.com/v1",
      "api_key": "${OPENAI_API_KEY}"
    },
    {
      "name": "anthropic-fast",
      "provider_type": "anthropic",
      "base_url": "https://api.anthropic.com",
      "api_key": "${ANTHROPIC_API_KEY}"
    },
    {
      "name": "aggregator-dual",
      "provider_type": "custom_dual",
      "base_url": "https://api.example.com/v1",
      "anthropic_base_url": "https://api.example.com/anthropic",
      "api_key": "${CUSTOM_DUAL_API_KEY}"
    },
    {
      "name": "minimax-coding",
      "provider_type": "minimax",
      "base_url": "https://api.minimax.chat/v1",
      "api_key": "${MINIMAX_API_KEY}"
    }
  ],
  "routers": [
    {
      "name": "default",
      "rules": [
        {
          "match": {
            "models": ["*"]
          },
          "channels": [
            {
              "name": "openai-coding",
              "weight": 1
            },
            {
              "name": "anthropic-fast",
              "weight": 1
            }
          ],
          "strategy": "round_robin"
        }
      ],
      "fallback_channels": ["minimax-coding"]
    }
  ],
  "teams": [
    {
      "id": "demo-team",
      "api_key": "REPLACE-WITH-YOUR-TEAM-API-KEY",
      "policy": {
        "allowed_routers": ["default"]
      }
    }
  ],
  "metrics": {
    "enabled": true,
    "path": "/metrics"
  },
  "hot_reload": {
    "config_path": "/absolute/path/to/apex/config.json",
    "watch": true
  },
  "retention": {
    "days": 90,
    "interval_hours": 24
  }
}
